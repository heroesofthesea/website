---
// Privacy Policy page (/privacy)
// Powered by src/content/pages/privacy.md
// Uses ArticleLayout for the TOC sidebar + reading time treatment
import { getEntry } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';

const entry = await getEntry('pages', 'privacy');
if (!entry) throw new Error('Privacy page content not found');

const { Content, headings } = await entry.render();
---

<ArticleLayout
  title={entry.data.title}
  description="Heroes of the Sea privacy policy — how we collect and use information."
  headings={headings}
  body={entry.body}
  category="Legal"
>
  <Content />
</ArticleLayout>
